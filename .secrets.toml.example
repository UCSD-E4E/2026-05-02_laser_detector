# Copy to `.secrets.toml` and fill in. `.secrets.toml` is gitignored.
#
# The API base URL goes in `settings.toml` (committed) — only credentials
# belong here.

[api]
username = ""
password = ""

[mlflow]
# Username is the email address shown on your mlflow-oidc-auth UI profile
# (after completing OIDC browser login at the configured tracking server).
# Token is the API token generated from that same profile page.
username = ""
token = ""
